---
import Base from "../layouts/Base.astro";
import { SITE, ORG_SCHEMA } from "../data/site.js";
import { PRACTICES } from "../data/practices.js";

const areas = SITE.areas.join(", ");
const localSchema = { ...ORG_SCHEMA, "@type": ["AccountingService", "LocalBusiness"] };
const title = "Chartered Accountants in Mumbai | DPS & Co";
const description = "Mumbai Chartered Accountants offering GST, income tax, company incorporation, audit and advisory. Established 2016. Contact us.";
---
<Base title={title} description={description} active="Home" schemas={[localSchema]} hasHero={true}>
  <section class="hero" slot="hero"><div class="wrap">
    <p class="eyebrow">Tax &middot; Audit &middot; Advisory</p>
    <h1>Chartered Accountants in Mumbai</h1>
    <p>{SITE.name} works with businesses and individuals across {areas} — combining technical depth with a partner-led, personal approach.</p>
    <div class="actions"><a class="cta-btn" href="/practices/">Explore our practices</a><a class="ghost" href="/contact/">Talk to us</a></div>
    <div class="stat-cards">
      <div class="stat"><div class="n">{SITE.founded}</div><div class="l">Year established</div></div>
      <div class="stat"><div class="n">39+ yrs</div><div class="l">Founding partner experience</div></div>
      <div class="stat"><div class="n">5</div><div class="l">Partners</div></div>
      <div class="stat"><div class="n">Mumbai</div><div class="l">Thane &amp; Navi Mumbai</div></div>
    </div>
  </div></section>

  <section>
    <p class="eyebrow">What we do</p><h2>Our practice areas</h2>
    <p class="lede">Four practice areas, each with focused services beneath it.</p>
    <div class="grid cols-2" style="margin-top:20px">
      {PRACTICES.map((p) => (
        <a class="tile" href={`/practices/${p.slug}/`}>
          <div class="ic" set:html={p.icon} />
          <h3>{p.name}</h3>
          <p>{p.desc}</p>
        </a>
      ))}
    </div>
    <p style="margin-top:18px"><a class="more" href="/services/">Browse all services &rsaquo;</a></p>
  </section>

  <section class="trust" style="margin:48px -22px 0"><div class="wrap"><div class="grid">
    <div><div class="n">{SITE.founded}</div><div class="muted">Established</div></div>
    <div><div class="n">ICAI</div><div class="muted">Chartered Accountants</div></div>
    <div><div class="n">5</div><div class="muted">Partners</div></div>
    <div><div class="n">Mumbai</div><div class="muted">{areas}</div></div>
  </div></div></section>

  <section style="margin-top:48px">
    <p class="eyebrow">Sectors</p><h2>Industries we serve</h2>
    <p class="lede">We work with clients across real estate, financial services, IT, manufacturing, and more.</p>
    <p style="margin-top:10px"><a class="more" href="/industries/">See all industries &rsaquo;</a></p>
  </section>

  <div class="ctaband"><h2>Let's talk</h2><p>Tell us about your business and the support you need. We serve clients across {areas}.</p><a class="cta-btn" href="/contact/">Contact us</a></div>
</Base>
